{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.upkick.dev/templates-index.schema.json",
  "title": "Upkick Templates Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "templates"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "templates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/template"
      }
    }
  },
  "$defs": {
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "latest",
        "status",
        "default",
        "category",
        "tags",
        "release"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "latest": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "status": {
          "type": "string",
          "enum": ["stable", "beta", "alpha", "deprecated"]
        },
        "default": {
          "type": "boolean"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "release": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "archive", "checksum", "metadata"],
          "properties": {
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "archive": {
              "type": "string",
              "pattern": "^[a-z0-9-]+\\.tar\\.gz$"
            },
            "checksum": {
              "type": "string",
              "pattern": "^[a-z0-9-]+\\.sha256$"
            },
            "metadata": {
              "type": "string",
              "const": "upkick.template.json"
            }
          }
        }
      }
    }
  }
}
