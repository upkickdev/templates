{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.upkick.dev/template.schema.json",
  "title": "Upkick Template",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "description",
    "version",
    "status",
    "default",
    "category",
    "tags",
    "requirements",
    "defaults"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["stable", "beta", "alpha", "deprecated"]
    },
    "default": {
      "type": "boolean"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "packageManagers"],
      "properties": {
        "node": {
          "type": "string"
        },
        "packageManagers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pnpm", "npm", "bun", "yarn"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageManager", "installDependencies", "initializeGit"],
      "properties": {
        "packageManager": {
          "type": "string",
          "enum": ["pnpm", "npm", "bun", "yarn"]
        },
        "installDependencies": {
          "type": "boolean"
        },
        "initializeGit": {
          "type": "boolean"
        }
      }
    }
  }
}
